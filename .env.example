# LAPIE Studio — Configuration
# Copier ce fichier en .env et ajuster les valeurs

# === Modèle de détourage ===
# Options: u2net (défaut), u2netp (rapide), isnet-general-use (HQ), birefnet-general (RMBG-1.4 like)
REMBG_MODEL=u2net

# === URLs (ne pas modifier sauf configuration réseau avancée) ===
NEXT_PUBLIC_API_URL=http://localhost:8000
